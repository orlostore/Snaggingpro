{
  "name": "snaggingpro",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Mobile-first property condition assessment PWA for UAE handover and DLP inspections",
  "scripts": {
    "dev": "vite",
    "dev:cloud": "wrangler pages dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "functions:typecheck": "tsc -p functions/tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "lit-html": "^3.2.1",
    "signature_pad": "^5.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.1",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^15.11.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8",
    "wrangler": "^4.103.0"
  }
}
